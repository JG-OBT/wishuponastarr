<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 800">
    <defs>
      <linearGradient id="grad-characters-fairy" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#fdf4ff;stop-opacity:1" />
      </linearGradient>
    </defs>
    <rect width="100%" height="100%" fill="url(#grad-characters-fairy)" />
    
    <!-- Background grid decoration -->
    <g opacity="0.05" stroke="#86198f" stroke-width="2">
      <line x1="0" y1="200" x2="600" y2="200" />
      <line x1="0" y1="400" x2="600" y2="400" />
      <line x1="0" y1="600" x2="600" y2="600" />
      <line x1="150" y1="0" x2="150" y2="800" />
      <line x1="300" y1="0" x2="300" y2="800" />
      <line x1="450" y1="0" x2="450" y2="800" />
    </g>
    
    <!-- Custom shape decoration -->
    <g fill="#86198f" opacity="0.3" transform="scale(1.5) translate(100, 50)">
        <line x1="20" y1="130" x2="100" y2="50" stroke="#86198f" stroke-width="8" stroke-linecap="round"/>
        <polygon points="100,30 105,45 120,45 108,55 112,70 100,60 88,70 92,55 80,45 95,45"/>
      </g>

    <g transform="translate(0, 380)">
      <text x="50%" y="0" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', system-ui, -apple-system, sans-serif" font-size="28" font-weight="bold" fill="#86198f">
        Fairies & Magical Friends
      </text>
      <text x="50%" y="40" dominant-baseline="middle" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="14" fill="#86198f" letter-spacing="1" opacity="0.7">
        Fairy Selection (600x800)
      </text>
      <text x="50%" y="80" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', sans-serif" font-size="14" fill="#86198f" opacity="0.5">
        Wish Upon a Starre Dorset • Client Image Asset: /assets/images/characters-fairy.jpg
      </text>
    </g>

    <!-- Star clusters in corners -->
    <path d="M30 40 L35 55 L50 55 L38 65 L42 80 L30 70 L18 80 L22 65 L10 55 L25 55 Z" fill="#eab308" opacity="0.3" />
    <path d="M550 740 L555 755 L570 755 L558 765 L562 780 L550 770 L538 780 L542 765 L530 755 L545 755 Z" fill="#eab308" opacity="0.3" />
  </svg>