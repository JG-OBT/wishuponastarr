<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 800">
    <defs>
      <linearGradient id="grad-home-gallery-02-character-visit" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#faf5ff;stop-opacity:1" />
      </linearGradient>
    </defs>
    <rect width="100%" height="100%" fill="url(#grad-home-gallery-02-character-visit)" />
    
    <!-- Background grid decoration -->
    <g opacity="0.05" stroke="#5b21b6" stroke-width="2">
      <line x1="0" y1="200" x2="800" y2="200" />
      <line x1="0" y1="400" x2="800" y2="400" />
      <line x1="0" y1="600" x2="800" y2="600" />
      <line x1="200" y1="0" x2="200" y2="800" />
      <line x1="400" y1="0" x2="400" y2="800" />
      <line x1="600" y1="0" x2="600" y2="800" />
    </g>
    
    <!-- Custom shape decoration -->
    <polygon points="100,30 120,70 170,75 130,110 140,150 100,130 60,150 70,110 30,75 80,70" fill="#5b21b6" opacity="0.3" transform="scale(1.5) translate(100, 50)" />

    <g transform="translate(0, 380)">
      <text x="50%" y="0" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', system-ui, -apple-system, sans-serif" font-size="42" font-weight="bold" fill="#5b21b6">
        Magical Character Visits
      </text>
      <text x="50%" y="55" dominant-baseline="middle" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="18" fill="#5b21b6" letter-spacing="1" opacity="0.7">
        Gallery Image 2 (600x600)
      </text>
      <text x="50%" y="110" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', sans-serif" font-size="14" fill="#5b21b6" opacity="0.5">
        Wish Upon a Starre Dorset • Client Image Asset: /assets/images/home-gallery-02-character-visit.jpg
      </text>
    </g>

    <!-- Star clusters in corners -->
    <path d="M30 40 L35 55 L50 55 L38 65 L42 80 L30 70 L18 80 L22 65 L10 55 L25 55 Z" fill="#eab308" opacity="0.3" />
    <path d="M750 740 L755 755 L770 755 L758 765 L762 780 L750 770 L738 780 L742 765 L730 755 L745 755 Z" fill="#eab308" opacity="0.3" />
  </svg>