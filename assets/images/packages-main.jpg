<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 675">
    <defs>
      <linearGradient id="grad-packages-main" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#fffbeb;stop-opacity:1" />
      </linearGradient>
    </defs>
    <rect width="100%" height="100%" fill="url(#grad-packages-main)" />
    
    <!-- Background grid decoration -->
    <g opacity="0.05" stroke="#78350f" stroke-width="2">
      <line x1="0" y1="168.75" x2="1200" y2="168.75" />
      <line x1="0" y1="337.5" x2="1200" y2="337.5" />
      <line x1="0" y1="506.25" x2="1200" y2="506.25" />
      <line x1="300" y1="0" x2="300" y2="675" />
      <line x1="600" y1="0" x2="600" y2="675" />
      <line x1="900" y1="0" x2="900" y2="675" />
    </g>
    
    <!-- Custom shape decoration -->
    <g fill="#78350f" opacity="0.2" transform="scale(1.5) translate(100, 50)">
        <path d="M50 10 Q50 50 10 50 Q50 50 50 90 Q50 50 90 50 Q50 50 50 10 Z"/>
        <path d="M120 30 Q120 50 100 50 Q120 50 120 70 Q120 50 140 50 Q120 50 120 30 Z" opacity="0.7"/>
      </g>

    <g transform="translate(0, 317.5)">
      <text x="50%" y="0" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', system-ui, -apple-system, sans-serif" font-size="42" font-weight="bold" fill="#78350f">
        Packages & Prices
      </text>
      <text x="50%" y="55" dominant-baseline="middle" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="18" fill="#78350f" letter-spacing="1" opacity="0.7">
        Main Page Banner (1200x500)
      </text>
      <text x="50%" y="110" dominant-baseline="middle" text-anchor="middle" font-family="'Inter', sans-serif" font-size="14" fill="#78350f" opacity="0.5">
        Wish Upon a Starre Dorset • Client Image Asset: /assets/images/packages-main.jpg
      </text>
    </g>

    <!-- Star clusters in corners -->
    <path d="M30 40 L35 55 L50 55 L38 65 L42 80 L30 70 L18 80 L22 65 L10 55 L25 55 Z" fill="#eab308" opacity="0.3" />
    <path d="M1150 615 L1155 630 L1170 630 L1158 640 L1162 655 L1150 645 L1138 655 L1142 640 L1130 630 L1145 630 Z" fill="#eab308" opacity="0.3" />
  </svg>